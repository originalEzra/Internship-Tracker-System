    {
      "name": "17 Cross-user Internship Isolation",
      "item": [
        {
          "name": "17.1 Create Internship As User A",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/internships",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"company\": \"User A Private Company\",\n  \"position\": \"Private Internship\",\n  \"location\": \"Sydney\",\n  \"status\": \"Applied\",\n  \"applicationUrl\": \"https://example.com/private\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create private internship as user A', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('internshipId', json.data.id);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "17.2 Register User B",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/users",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userBUsername}}\",\n  \"email\": \"{{userBEmail}}\",\n  \"password\": \"{{userBPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register user B success', function () {",
                  "  pm.response.to.have.status(200);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "17.3 Login User B",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{baseUrl}}/api/users/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"{{userBUsername}}\",\n  \"password\": \"{{userBPassword}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('login user B success', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.collectionVariables.set('userBToken', json.data.token);",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "17.4 User B Finds User A Internship",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{userBToken}}"
              }
            ],
            "url": "{{baseUrl}}/api/users/me"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('user B wrapper request succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "pm.sendRequest({",
                  "  url: pm.collectionVariables.get('baseUrl') + '/api/internships/' + pm.collectionVariables.get('internshipId'),",
                  "  method: 'GET',",
                  "  header: { Authorization: 'Bearer ' + pm.collectionVariables.get('userBToken') }",
                  "}, function (err, res) {",
                  "  pm.test('user B cannot find user A internship with 404', function () {",
                  "    pm.expect(err).to.eql(null);",
                  "    pm.expect(res.code).to.eql(404);",
                  "    pm.expect(res.json().code).to.eql(404);",
                  "  });",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "17.5 User B Updates User A Internship",
          "request": {
            "method": "GET",
