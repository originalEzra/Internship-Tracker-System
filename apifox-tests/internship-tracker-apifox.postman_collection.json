        }
      ]
    },
    {
      "name": "12 Update Own Internship",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/internships/{{internshipId}}",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company\": \"Apifox Company Updated\",\n  \"position\": \"Backend Intern Updated\",\n  \"location\": \"Melbourne\",\n  \"status\": \"ONLINE_ASSESSMENT\",\n  \"applicationUrl\": \"https://example.com/job-updated\",\n  \"statusNote\": \"Received OA\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('update own internship success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.id).to.eql(Number(pm.collectionVariables.get('internshipId')));",
              "  pm.expect(json.data.company).to.eql('Apifox Company Updated');",
              "  pm.expect(json.data.status).to.eql('ONLINE_ASSESSMENT');",
