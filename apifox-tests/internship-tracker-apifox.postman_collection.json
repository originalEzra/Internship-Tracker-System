    {
      "name": "06 Change Password",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/me/password",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"oldPassword\": \"{{userAPassword}}\",\n  \"newPassword\": \"{{userANewPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('change password success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.message).to.eql('Password updated');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "07 Login Old Password Should Fail",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('authorized wrapper request succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.sendRequest({",
              "  url: pm.collectionVariables.get('baseUrl') + '/api/users/login',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      username: pm.collectionVariables.get('userANewUsername'),",
              "      password: pm.collectionVariables.get('userAPassword')",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  pm.test('old password login fails with 401', function () {",
              "    pm.expect(err).to.eql(null);",
              "    pm.expect(res.code).to.eql(401);",
              "    pm.expect(res.json().code).to.eql(401);",
              "  });",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "08 Login New Password",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{userANewUsername}}\",\n  \"password\": \"{{userANewPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('new password login succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.refreshToken).to.be.a('string');",
              "  pm.collectionVariables.set('newToken', json.data.token);",
              "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "  pm.collectionVariables.set('token', json.data.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "08.1 Refresh Access Token",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": "{{baseUrl}}/api/users/refresh-token"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('refresh token returns new access token', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.collectionVariables.set('refreshedToken', json.data.token);",
              "  pm.collectionVariables.set('token', json.data.token);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "09 Create Internship",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/internships",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"company\": \"Apifox Company\",\n  \"position\": \"Backend Intern\",\n  \"location\": \"Sydney\",\n  \"status\": \"APPLIED\",\n  \"applicationUrl\": \"https://example.com/job\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('create internship success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.id).to.be.a('number');",
              "  pm.expect(json.data.createdAt).to.be.a('string');",
              "  pm.expect(json.data.updatedAt).to.be.a('string');",
              "  pm.expect(json.data.userId).to.eql(undefined);",
              "  pm.collectionVariables.set('internshipId', json.data.id);",
              "  pm.collectionVariables.set('internshipCreatedAt', json.data.createdAt);",
              "  pm.collectionVariables.set('internshipUpdatedAt', json.data.updatedAt);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "10 Get My Internships",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/internships?page=0&size=10&status=APPLIED&keyword=Apifox&sort=updatedAt,desc"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get my internships contains created internship', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.content).to.be.an('array');",
              "  const internshipId = Number(pm.collectionVariables.get('internshipId'));",
              "  const item = json.data.content.find(item => item.id === internshipId);",
              "  pm.expect(item).to.not.eql(undefined);",
              "  pm.expect(item.updatedAt).to.be.a('string');",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "11 Find Internship By Id",
