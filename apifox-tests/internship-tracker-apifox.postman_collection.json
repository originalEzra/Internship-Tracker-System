  "item": [
    {
      "name": "00 Initialize Test Data",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('initialize wrapper request succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "});",
              "const runId = Date.now().toString();",
              "pm.collectionVariables.set('runId', runId);",
              "pm.collectionVariables.set('token', '');",
              "pm.collectionVariables.set('refreshToken', '');",
              "pm.collectionVariables.set('refreshedToken', '');",
              "pm.collectionVariables.set('newToken', '');",
              "pm.collectionVariables.set('userId', '');",
              "pm.collectionVariables.set('internshipId', '');",
              "pm.collectionVariables.set('internshipCreatedAt', '');",
              "pm.collectionVariables.set('internshipUpdatedAt', '');",
              "pm.collectionVariables.set('internshipUpdatedAtAfterUpdate', '');",
              "pm.collectionVariables.set('userBToken', '');",
              "pm.collectionVariables.set('userAUsername', 'apifox_user_a_' + runId);",
              "pm.collectionVariables.set('userAEmail', 'apifox_user_a_' + runId + '@example.com');",
              "pm.collectionVariables.set('userANewUsername', 'apifox_user_a_updated_' + runId);",
              "pm.collectionVariables.set('userANewEmail', 'apifox_user_a_updated_' + runId + '@example.com');",
              "pm.collectionVariables.set('userBUsername', 'apifox_user_b_' + runId);",
              "pm.collectionVariables.set('userBEmail', 'apifox_user_b_' + runId + '@example.com');",
              "console.log('initialized Apifox runId:', runId);"
            ]
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/health"
      }
    },
    {
      "name": "01 Register User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{userAUsername}}\",\n  \"email\": \"{{userAEmail}}\",\n  \"password\": \"{{userAPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('register user A success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.username).to.eql(pm.collectionVariables.get('userAUsername'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "02 Login User A",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/login",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{userAUsername}}\",\n  \"password\": \"{{userAPassword}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('login user A success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.expect(json.data.refreshToken).to.be.a('string');",
              "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);",
              "  pm.collectionVariables.set('token', json.data.token);",
              "  pm.collectionVariables.set('userId', json.data.user.id);",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "03 Get Current User",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "url": "{{baseUrl}}/api/users/me"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('get current user success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.id).to.eql(Number(pm.collectionVariables.get('userId')));",
              "  pm.expect(json.data.username).to.eql(pm.collectionVariables.get('userAUsername'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "04 Update Current User",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "url": "{{baseUrl}}/api/users/me",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"{{userANewUsername}}\",\n  \"email\": \"{{userANewEmail}}\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('update current user success', function () {",
              "  pm.response.to.have.status(200);",
              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.username).to.eql(pm.collectionVariables.get('userANewUsername'));",
              "  pm.expect(json.data.email).to.eql(pm.collectionVariables.get('userANewEmail'));",
              "});"
            ]
          }
        }
      ]
    },
    {
      "name": "05 Get Current User After Update",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
