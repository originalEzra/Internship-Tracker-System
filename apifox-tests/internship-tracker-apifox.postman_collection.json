              "  const json = pm.response.json();",
              "  pm.expect(json.code).to.eql(200);",
              "  pm.expect(json.data.token).to.be.a('string');",
              "  pm.collectionVariables.set('token', json.data.token);",
              "  pm.collectionVariables.set('userId', json.data.user.id);",
              "});"
