      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('authorized wrapper request succeeds', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "pm.sendRequest({",
              "  url: pm.collectionVariables.get('baseUrl') + '/api/users/login',",
              "  method: 'POST',",
              "  header: { 'Content-Type': 'application/json' },",
              "  body: {",
              "    mode: 'raw',",
              "    raw: JSON.stringify({",
              "      username: pm.collectionVariables.get('userANewUsername'),",
              "      password: pm.collectionVariables.get('userAPassword')",
              "    })",
              "  }",
              "}, function (err, res) {",
              "  pm.test('old password login fails with 401', function () {",
              "    pm.expect(err).to.eql(null);",
              "    pm.expect(res.code).to.eql(401);",
              "    pm.expect(res.json().code).to.eql(401);",
              "  });",
              "});"
            ]
          }
        }
